# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Comma-separated Telegram user IDs allowed to interact with the bot
# Find yours: message @userinfobot on Telegram
ALLOWED_USER_IDS=123456789

# ── Google AI Studio (Gemini) ─────────────────────────────
GEMINI_API_KEY=your-google-ai-studio-api-key

# Model to use (optional, defaults shown)
GEMINI_MODEL=gemini-3-flash-preview

# ── Database ──────────────────────────────────────────────
# Used by the bot to connect to PostgreSQL
DATABASE_URL=postgresql://gravityclaw:your-secure-password@postgres:5432/gravityclaw

# Used by docker-compose for the PostgreSQL container
POSTGRES_PASSWORD=your-secure-password

# ── Agent Identity ────────────────────────────────────────
# The agent's own email (for sending emails, e.g. nodemailer fallback)
AGENT_EMAIL=your-agent@gmail.com
AGENT_EMAIL_PASSWORD=app-password-here

# ── Google APIs (OAuth2) ──────────────────────────────────
# Used for Gmail, Google Drive, Google Calendar, Google Tasks.
# Go to Google Cloud Console -> APIs & Services -> Credentials
# Create an OAuth 2.0 Client ID (Type: Desktop or Web)
# Note: You can still use the legacy GMAIL_ environment variables if preferred.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Refresh Tokens for each Google Account Volt manages
# Required OAuth Scopes: 
# - https://mail.google.com/
# - https://www.googleapis.com/auth/drive
# - https://www.googleapis.com/auth/calendar
# - https://www.googleapis.com/auth/tasks
GOOGLE_PERSONAL1_EMAIL=your-main-email@gmail.com
GOOGLE_PERSONAL1_REFRESH_TOKEN=your-refresh-token-here

# Optional secondary/work accounts
# GOOGLE_PERSONAL2_EMAIL=
# GOOGLE_PERSONAL2_REFRESH_TOKEN=
# GOOGLE_WORK_EMAIL=
# GOOGLE_WORK_REFRESH_TOKEN=

# ── Heartbeat (Proactive Messages) ────────────────────────
# Your Telegram chat ID — where heartbeats are sent
HEARTBEAT_CHAT_ID=1354369388

# Timezone for scheduling (IANA format)
TIMEZONE=America/Monterrey

# ── Agent ─────────────────────────────────────────────────
# Max agentic loop iterations before force-stopping (safety limit)
MAX_ITERATIONS=10

# ── Logging ───────────────────────────────────────────────
# "debug" | "info" | "warn" | "error"
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# ── Notion ────────────────────────────────────────────────
# Used for Business Automation & Workspace Management
NOTION_API_KEY=your-notion-secret-api-key
