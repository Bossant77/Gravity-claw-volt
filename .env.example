# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Comma-separated Telegram user IDs allowed to interact with the bot
# Find yours: message @userinfobot on Telegram
ALLOWED_USER_IDS=123456789

# ── Google AI Studio (Gemini) ─────────────────────────────
GEMINI_API_KEY=your-google-ai-studio-api-key

# Model to use (optional, defaults shown)
GEMINI_MODEL=gemini-3-flash-preview

# ── Database ──────────────────────────────────────────────
# Used by the bot to connect to PostgreSQL
DATABASE_URL=postgresql://gravityclaw:your-secure-password@postgres:5432/gravityclaw

# Used by docker-compose for the PostgreSQL container
POSTGRES_PASSWORD=your-secure-password

# ── Agent ─────────────────────────────────────────────────
# Max agentic loop iterations before force-stopping (safety limit)
MAX_ITERATIONS=10

# ── Logging ───────────────────────────────────────────────
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=info
